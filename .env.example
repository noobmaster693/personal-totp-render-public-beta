# Copy to .env for local testing. Never commit the real .env.

APP_ENV=development

# Generate:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret

# Generate:
# python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_KEY_PEPPER=replace-with-a-different-random-secret

# Generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=replace-with-a-fernet-key

# Local only. Use a persistent Render PostgreSQL URL in production.
DATABASE_URL=sqlite:///local.db
SESSION_COOKIE_SECURE=false

# Existing authenticator credential. Accepts Base32 or an otpauth://totp URI.
TOTP_SECRET=JBSWY3DPEHPK3PXP
TOTP_LABEL=Main Software Account
TOTP_ISSUER=Your Software

# The single email-based software account delivered to buyers.
SOFTWARE_PROVIDER=Gmail
SOFTWARE_LOGIN_EMAIL=account@example.com
SOFTWARE_LOGIN_PASSWORD=replace-with-the-software-password

PUBLIC_BASE_URL=http://127.0.0.1:5000

# Generate the password hash with:
# python manage.py hash-admin-password
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Use a separate Base32 secret, not the buyer account's TOTP secret.
ADMIN_TOTP_SECRET=
ADMIN_SESSION_HOURS=4
ADMIN_LOGIN_ATTEMPTS=10
ADMIN_LOGIN_WINDOW_SECONDS=900

# Keep false until G2G approves API access and all values are configured.
G2G_INTEGRATION_ENABLED=false
G2G_API_BASE=https://open-api.g2g.com
G2G_API_VERSION=v2
G2G_API_KEY=
G2G_API_SECRET=
G2G_USER_ID=
G2G_WEBHOOK_SECRET=
G2G_WEBHOOK_CANONICAL_URL=http://127.0.0.1:5000/webhooks/g2g
G2G_WEBHOOK_MAX_AGE_SECONDS=300
G2G_REQUIRE_SELLER_MATCH=true
G2G_DELIVERY_PATH_TEMPLATE=/{version}/orders/{order_id}/delivery
G2G_DELIVERY_STATUS_PATH_TEMPLATE=/{version}/orders/{order_id}/delivery/{delivery_id}
G2G_DELIVERY_MAX_ATTEMPTS=8
G2G_DELIVERY_RETRY_BASE_SECONDS=60
G2G_DELIVERY_STALE_SECONDS=120

# Replace OFFER_ID values with the exact offer IDs sent by G2G.
G2G_PRODUCTS_JSON={"OFFER_ID_30D":{"name":"Software access - 30 days","duration_days":30},"OFFER_ID_90D":{"name":"Software access - 90 days","duration_days":90}}

RATE_LIMIT_ATTEMPTS=12
RATE_LIMIT_WINDOW_SECONDS=300

# Zero means unlimited. Set positive values only if desired.
MAX_ACTIVE_SESSIONS_PER_ORDER=0
MAX_DISTINCT_IPS_PER_ORDER=0

# Records public GET / visits for the admin visitor report. IP addresses may be
# personal data; choose retention and disclosures appropriate to your users.
VISITOR_LOG_ENABLED=true
VISITOR_LOG_RETENTION_DAYS=90
